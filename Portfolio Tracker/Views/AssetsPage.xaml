<Page
    x:Class="Portfolio_Tracker.Views.AssetsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource MainBackground}"
    Loaded="Page_Loaded"
    Opacity="0">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Margin="0,0,0,20"
            FontSize="28"
            FontWeight="Bold"
            Foreground="{DynamicResource TextColor}"
            Text="{DynamicResource Assets}" />

        <!--  Контролі: Додати/Редагувати/Видалити + Пошук/Фільтр/Сортування  -->
        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,15"
            VerticalAlignment="Center"
            Orientation="Horizontal">
            <StackPanel Orientation="Horizontal">
                <Button
                    Margin="5"
                    Padding="8"
                    Background="{DynamicResource ButtonPrimaryBackground}"
                    Click="Add_Click"
                    Content="{DynamicResource AddTransaction}"
                    FontSize="15"
                    Foreground="{DynamicResource ButtonPrimaryForeground}" />
                <Button
                    Margin="5"
                    Padding="8"
                    Background="{DynamicResource ButtonPrimaryBackground}"
                    Click="Edit_Click"
                    Content="{DynamicResource Edit}"
                    FontSize="15"
                    Foreground="{DynamicResource ButtonPrimaryForeground}" />
                <Button
                    Margin="5"
                    Padding="8"
                    Background="{DynamicResource ButtonDangerBackground}"
                    Click="Delete_Click"
                    Content="{DynamicResource Delete}"
                    FontSize="15"
                    Foreground="{DynamicResource ButtonDangerForeground}" />
            </StackPanel>

            <!--  Відступ  -->
            <Grid Width="10" />

            <!--  Мітка пошуку  -->
            <TextBlock
                Margin="5,0,5,0"
                VerticalAlignment="Center"
                Foreground="{DynamicResource TextColor}"
                Text="Search" />
            <TextBox
                Width="140"
                Margin="0,5,5,5"
                VerticalAlignment="Center"
                Background="White"
                FontSize="14"
                Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />

            <!--  Фільтр за типом активу  -->
            <ComboBox
                Width="70"
                Height="30"
                Margin="5"
                Background="White"
                FontSize="14"
                ItemsSource="{Binding AssetTypes}"
                SelectedItem="{Binding SelectedAssetType, Mode=TwoWay}" />

            <!--  Параметри сортування  -->
            <ComboBox
                Width="70"
                Height="30"
                Margin="5"
                Background="White"
                FontSize="14"
                ItemsSource="{Binding SortOptions}"
                SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}" />
        </StackPanel>

        <Border
            Grid.Row="2"
            Padding="12"
            Background="{DynamicResource CardBackground}"
            BorderBrush="#2E2E4F"
            BorderThickness="1"
            CornerRadius="8">
            <DataGrid
                x:Name="AssetsGrid"
                AlternatingRowBackground="White"
                AutoGenerateColumns="False"
                Background="White"
                BorderThickness="0"
                CanUserAddRows="False"
                CanUserDeleteRows="True"
                CanUserSortColumns="False"
                FontSize="15"
                Foreground="{DynamicResource TableTextColor}"
                IsReadOnly="False"
                ItemsSource="{Binding AssetsView}"
                RowBackground="White"
                RowEditEnding="AssetsGrid_RowEditEnding"
                SelectedItem="{Binding SelectedAsset, Mode=TwoWay}">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{DynamicResource TableTextColor}" />
                        <Setter Property="Background" Value="White" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="{DynamicResource TableTextColor}" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Background" Value="White" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}" />
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="60"
                        Binding="{Binding Symbol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                        Header="{DynamicResource Symbol}" />
                    <DataGridTextColumn
                        Width="2*"
                        Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                        Header="{DynamicResource Name}" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding AssetType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Header="{DynamicResource AssetType}" />
                    <DataGridTextColumn
                        Width="80"
                        Binding="{Binding Currency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                        Header="{DynamicResource Currency}" />
                    <DataGridTextColumn
                        Width="100"
                        Binding="{Binding CurrentPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                        Header="{DynamicResource CurrentPrice}" />
                    <DataGridTextColumn
                        Width="140"
                        Binding="{Binding LastUpdated, Mode=OneWay, StringFormat=dd.MM.yyyy HH:mm}"
                        Header="Last Updated"
                        IsReadOnly="True" />
                </DataGrid.Columns>

            </DataGrid>
        </Border>

    </Grid>
</Page>