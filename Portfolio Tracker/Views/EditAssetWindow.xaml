<Window
    x:Class="Portfolio_Tracker.Views.EditAssetWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Редагування активу"
    Width="300"
    Height="380"
    Background="{DynamicResource MainBackground}"
    Loaded="Page_Loaded"
    Opacity="0"
    WindowStartupLocation="CenterScreen">

    <StackPanel Margin="20">

        <TextBlock
            FontSize="15"
            Foreground="{DynamicResource TextColor}"
            Text="{DynamicResource Symbol}" />
        <TextBox Margin="0,5,0,10" Text="{Binding Symbol, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

        <TextBlock
            FontSize="15"
            Foreground="{DynamicResource TextColor}"
            Text="{DynamicResource Name}" />
        <TextBox Margin="0,5,0,10" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

        <TextBlock
            FontSize="15"
            Foreground="{DynamicResource TextColor}"
            Text="{DynamicResource Type}" />
        <TextBox Margin="0,5,0,10" Text="{Binding AssetType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock
            FontSize="15"
            Foreground="{DynamicResource TextColor}"
            Text="{DynamicResource Currency}" />
        <TextBox Margin="0,5,0,10" Text="{Binding Currency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" />

        <TextBlock
            FontSize="15"
            Foreground="{DynamicResource TextColor}"
            Text="{DynamicResource CurrentPrice}" />
        <TextBox Margin="0,5,0,10" Text="{Binding CurrentPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <Button
            Margin="0,10,0,0"
            Background="{DynamicResource CardBackground}"
            Click="Save_Click"
            Content="{DynamicResource Save}"
            FontSize="15"
            Foreground="{DynamicResource TextColor}" />

    </StackPanel>
</Window>