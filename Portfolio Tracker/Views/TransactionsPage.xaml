<Page
    x:Class="Portfolio_Tracker.Views.TransactionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{DynamicResource MainBackground}"
    Loaded="Page_Loaded"
    Opacity="0">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Margin="0,0,0,20"
            FontSize="28"
            FontWeight="Bold"
            Foreground="{DynamicResource TextColor}"
            Text="{DynamicResource Transactions}" />

        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,15"
            Orientation="Horizontal">

            <Button
                Margin="5"
                Padding="8"
                Background="{DynamicResource ButtonPrimaryBackground}"
                Click="AddTransaction_Click"
                Content="{DynamicResource AddTransaction}"
                FontSize="15"
                Foreground="{DynamicResource ButtonPrimaryForeground}" />

            <Button
                Margin="5"
                Padding="8"
                Background="{DynamicResource ButtonPrimaryBackground}"
                Click="EditTransaction_Click"
                Content="{DynamicResource Edit}"
                FontSize="15"
                Foreground="{DynamicResource ButtonPrimaryForeground}" />

            <Button
                Margin="5"
                Padding="8"
                Background="{DynamicResource ButtonDangerBackground}"
                Click="DeleteTransaction_Click"
                Content="{DynamicResource Delete}"
                FontSize="15"
                Foreground="{DynamicResource ButtonDangerForeground}" />

        </StackPanel>

        <Border
            Grid.Row="2"
            Padding="12"
            Background="{DynamicResource CardBackground}"
            BorderBrush="#2E2E4F"
            BorderThickness="1"
            CornerRadius="8">

            <DataGrid
                x:Name="TransactionsGrid"
                Margin="0"
                AutoGenerateColumns="False"
                Background="Transparent"
                BorderThickness="0"
                CanUserDeleteRows="True"
                CanUserSortColumns="False"
                FontSize="14"
                Foreground="{DynamicResource TableTextColor}"
                IsReadOnly="False"
                ItemsSource="{Binding Transactions}"
                RowEditEnding="TransactionsGrid_RowEditEnding"
                SelectedItem="{Binding SelectedTransaction, Mode=TwoWay}">
                <DataGrid.Columns>
                    <DataGridTextColumn
                        Width="80"
                        Binding="{Binding Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Header="{DynamicResource Type}" />
                    <DataGridTextColumn
                        Width="120"
                        Binding="{Binding Asset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                        Header="{DynamicResource Asset}" />
                    <DataGridTextColumn
                        Width="90"
                        Binding="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                        Header="{DynamicResource Quantity}" />
                    <DataGridTextColumn
                        Width="90"
                        Binding="{Binding Price, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                        Header="{DynamicResource Price}" />
                    <DataGridTextColumn
                        Width="90"
                        Binding="{Binding Fees, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                        Header="{DynamicResource Fees}" />
                    <DataGridTextColumn
                        Width="100"
                        Binding="{Binding TotalAmount, Mode=OneWay, StringFormat=N2}"
                        Header="{DynamicResource TotalAmount}"
                        IsReadOnly="True" />
                    <DataGridTextColumn
                        Width="120"
                        Binding="{Binding Date, Mode=TwoWay, StringFormat=dd.MM.yyyy}"
                        Header="{DynamicResource Date}" />
                    <DataGridTextColumn
                        Width="*"
                        Binding="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        Header="{DynamicResource Notes}" />
                </DataGrid.Columns>
            </DataGrid>

        </Border>

    </Grid>
</Page>